generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Profile {
  id          String    @id
  name        String    @default("")
  bio         String    @default("")
  city        String?
  country     String?
  gender      Gender?
  birthDate   DateTime?
  interests   String[]
  photos      String[]
  embedding   Unsupported("vector(384)")?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([city])
  @@index([country])
}

model Interest {
  id       String @id @default(uuid())
  name     String
  category String

  @@unique([name])
}
