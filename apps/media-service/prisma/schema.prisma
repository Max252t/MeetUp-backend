generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MediaObject {
  id         String    @id @default(uuid())
  userId     String
  bucket     String
  key        String    @unique
  mimeType   String
  sizeBytes  BigInt
  status     String    @default("pending")
  url        String?
  uploadedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}
